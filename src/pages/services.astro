---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Doodle from "../components/Doodle.astro";
import Marquee from "../components/Marquee.astro";
import Scribble from "../components/Scribble.astro";

import weddingPhoto from "../assets/photos/services-couple.jpg";
import portraitPhoto from "../assets/photos/services-portrait.jpg";
import familiesPhoto from "../assets/photos/services-grad.jpg";
import miniPhoto from "../assets/photos/services-family.jpg";

const packages = [
	{
		title: "Portraits",
		price: "$450",
		note: "main character energy",
		photo: portraitPhoto,
		alt: "Woman in motion on a stone balustrade above marigold beds",
		copy: "One-hour outdoor session with up to two outfit changes. Includes unlimited edited photos delivered in a private online gallery for easy viewing and downloads.",
	},
	{
		title: "Couples & Families",
		price: "$495",
		note: "bring the whole crew",
		photo: familiesPhoto,
		alt: "Three kids sitting together in a grassy field",
		copy: "One-hour outdoor session for couples, engagements, or families of up to six. Includes unlimited professionally edited photos through a private online gallery.",
	},
	{
		title: "Mini Sessions",
		price: "from $295",
		note: "short + sweet",
		photo: miniPhoto,
		alt: "Family sitting together on courthouse steps",
		copy: "Available on select dates only. A 30-minute outdoor session at one location with one outfit. Inquire for upcoming availability.",
	},
];

const included = [
	"unlimited edited photos — never choose between favorites",
	"private online gallery for viewing + downloads",
	"location scouting help & outfit advice",
	"a hype-woman behind the camera, always",
];
---

<Layout title="Services & Pricing — Madd Photography">
	<main>
		<!-- hero -->
		<section class="relative mx-auto max-w-6xl px-5 pt-16 pb-14 text-center sm:px-10 sm:pt-24">
			<p class="reveal font-mono text-[11px] tracking-[0.32em] text-clay uppercase">✳ investment ✳</p>
			<h1
				class="reveal mx-auto mt-6 font-display text-5xl leading-[1.04] font-medium tracking-tight sm:text-8xl"
				style="--reveal-delay: 0.08s"
			>
				Worth every <Scribble kind="ring" color="var(--color-clay)">penny</Scribble>
			</h1>
			<p class="reveal mx-auto mt-8 max-w-lg text-lg leading-relaxed text-ink-soft" style="--reveal-delay: 0.16s">
				Simple packages, zero surprises — and every single one comes with unlimited edited
				images. Pick your adventure below.
			</p>
			<Doodle name="sparkle" class="absolute top-24 right-10 hidden h-8 w-8 rotate-12 text-butter lg:block" />
		</section>

		<!-- featured: weddings -->
		<section class="mx-auto max-w-7xl px-5 py-14 sm:px-10">
			<div class="reveal grid overflow-hidden rounded-[2rem] bg-cream md:grid-cols-2">
				<div class="relative h-full overflow-hidden">
					<Image
						src={weddingPhoto}
						alt="Bride and groom smiling under the bridal veil"
						widths={[600, 1000, 1400]}
						sizes="(max-width: 768px) 100vw, 50vw"
						class="h-full min-h-[24rem] w-full object-cover"
					/>
					<span class="sticker absolute top-6 left-6 rotate-[-3deg] font-mono text-[11px] font-bold tracking-[0.16em] uppercase">
						<Doodle name="heart" class="h-3.5 w-3.5 text-clay" /> the big one
					</span>
				</div>
				<div class="flex flex-col justify-center px-7 py-14 sm:px-14">
					<p class="font-mono text-[11px] tracking-[0.28em] text-ink-soft uppercase">starting at</p>
					<p class="mt-3 font-display text-6xl font-medium tracking-tight text-clay sm:text-7xl">$2,900</p>
					<h2 class="mt-6 font-display text-4xl font-medium tracking-tight sm:text-5xl">Weddings</h2>
					<p class="mt-6 max-w-md text-lg leading-relaxed text-ink-soft">
						Every love story is unique. Wedding photography packages are fully customizable and
						tailored to fit your special day — inquire for details and let's dream it up together.
					</p>
					<div class="mt-9">
						<Button href="/#contact">Inquire about your day</Button>
					</div>
				</div>
			</div>
		</section>

		<!-- package cards -->
		<section class="mx-auto max-w-7xl px-5 pb-10 sm:px-10">
			<div class="grid gap-10 md:grid-cols-3 md:gap-6">
				{
					packages.map((pkg, i) => (
						<article class="reveal group" style={`--reveal-delay: ${i * 0.1}s`}>
							<div class="relative overflow-hidden rounded-t-[2rem]">
								<Image
									src={pkg.photo}
									alt={pkg.alt}
									widths={[480, 800]}
									sizes="(max-width: 768px) 90vw, 30vw"
									class="aspect-[4/5] w-full object-cover transition-transform duration-1000 ease-fluid group-hover:scale-[1.05]"
								/>
								<span
									class="sticker absolute top-5 right-5 font-mono text-[12px] font-bold tracking-[0.1em]"
									style={`transform: rotate(${[3, -2, 2][i]}deg)`}
								>
									{pkg.price}
								</span>
							</div>
							<div class="border-x border-b border-line bg-paper px-6 py-8 rounded-b-[2rem]">
								<div class="flex items-center justify-between gap-3">
									<h3 class="font-display text-3xl font-medium tracking-tight">{pkg.title}</h3>
									<span class="hidden rotate-[-4deg] font-hand text-xl text-clay whitespace-nowrap sm:block">{pkg.note}</span>
								</div>
								<p class="mt-4 leading-relaxed text-ink-soft">{pkg.copy}</p>
								<a
									href="/#contact"
									class="mt-6 inline-flex items-center gap-2 font-mono text-[11px] font-bold tracking-[0.2em] uppercase transition-colors duration-500 ease-fluid hover:text-clay"
								>
									Book this
									<Doodle name="arrow-swoosh" class="h-5 w-5" />
								</a>
							</div>
						</article>
					))
				}
			</div>
		</section>

		<Marquee
			class="mt-20"
			items={[
				"unlimited edits",
				"always included",
				"private gallery",
				"easy downloads",
				"no stiff poses",
				"pinky promise",
			]}
		/>

		<!-- always included -->
		<section class="mx-auto max-w-4xl px-5 py-24 text-center sm:px-10 sm:py-32">
			<p class="reveal font-mono text-[11px] tracking-[0.32em] text-clay uppercase">in every single package</p>
			<ul class="reveal mx-auto mt-10 max-w-xl space-y-5 text-left" style="--reveal-delay: 0.1s">
				{
					included.map((item) => (
						<li class="flex items-start gap-4 border-b border-line pb-5">
							<Doodle name="star" class="mt-1 h-5 w-5 shrink-0 text-clay" />
							<span class="text-lg text-ink-soft">{item}</span>
						</li>
					))
				}
			</ul>
			<div class="reveal mt-12" style="--reveal-delay: 0.2s">
				<Button href="/#contact">Let's work together</Button>
			</div>
		</section>
	</main>
</Layout>
