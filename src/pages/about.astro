---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Doodle from "../components/Doodle.astro";
import Scribble from "../components/Scribble.astro";

import maddieWall from "../assets/photos/maddie-2.jpg";
import maddieChair from "../assets/photos/maddie-1.jpg";
import behindScenes from "../assets/photos/about-wide.jpg";

const facts = [
	"lifestyle photographer",
	"ambivert",
	"iced shaken espresso snob",
	"has a Harry Styles tattoo",
	"attended 200+ concerts",
];

const artists = ["Faye Webster", "Weezer", "SZA", "Bad Bunny", "Harry Styles"];
---

<Layout
	title="About Maddie — DFW Wedding & Lifestyle Photographer"
	description="Hi, I'm Maddie — a DFW photographer chasing laughter, movement, and the moments between the posed ones."
>
	<main id="main">
		<!-- annotated hero, IG-post style -->
		<section class="mx-auto max-w-6xl px-5 pt-14 sm:px-10 sm:pt-20">
			<p class="reveal text-center font-mono text-[11px] tracking-[0.32em] text-clay uppercase">
				✳ get to know me ✳
			</p>
			<div class="reveal relative mx-auto mt-8 max-w-3xl" style="--reveal-delay: 0.1s">
				<div class="photo-mat">
					<Image
						src={maddieWall}
						alt="Maddie crouching in her studio against a big blank wall"
						widths={[600, 1000, 1500]}
						sizes="(max-width: 768px) 92vw, 48rem"
						loading="eager"
						class="aspect-[3/4] w-full object-cover sm:aspect-[2/3]"
					/>
				</div>

				<!-- annotations over the blank wall (desktop-ish only) -->
				<div class="pointer-events-none absolute inset-0 hidden sm:block">
					<span class="absolute top-[7%] left-1/2 -translate-x-1/2 -rotate-2 font-display text-7xl font-black tracking-tight text-ink md:text-8xl">
						maddie
					</span>
					<Doodle name="sparkle" class="absolute top-[4%] left-[12%] h-9 w-9 -rotate-12 text-clay" />
					<Doodle name="crown" class="absolute top-[3.5%] right-[10%] h-11 w-11 rotate-12 text-clay" />

					<span class="absolute top-[24%] right-[6%] rotate-2 text-right font-hand text-3xl text-ink">
						lifestyle<br />photographer
					</span>
					<Doodle name="arrow-curl" class="absolute top-[34%] right-[16%] h-11 w-11 rotate-[160deg] text-ink" />

					<span class="absolute top-[30%] left-[7%] -rotate-3 font-hand text-3xl text-ink">ambivert</span>
					<Doodle name="squiggle" class="absolute top-[36%] left-[10%] h-9 w-9 rotate-45 text-ink" />

					<span class="absolute top-[48%] left-[5%] -rotate-2 font-hand text-2xl leading-tight text-ink">
						iced shaken<br />espresso snob
					</span>

					<span class="absolute top-[46%] right-[5%] rotate-2 font-hand text-2xl leading-tight text-ink">
						has a Harry<br />Styles tattoo
					</span>
					<Doodle name="heart" class="absolute top-[55%] right-[13%] h-7 w-7 rotate-12 text-clay" />

					<span class="absolute bottom-[9%] right-[6%] rotate-[-3deg] font-hand text-2xl leading-tight text-ink">
						attended 200+<br />concerts
					</span>
					<Doodle name="burst" class="absolute bottom-[18%] right-[20%] h-8 w-8 text-clay" />
				</div>
			</div>

			<!-- fact stickers (mobile fallback + fun on all sizes) -->
			<div class="reveal mt-10 flex flex-wrap items-center justify-center gap-3 sm:hidden">
				{
					facts.map((fact, i) => (
						<span
							class="sticker font-mono text-[10px] font-bold tracking-[0.12em] uppercase"
							style={`transform: rotate(${[-2, 1.5, -1, 2, -1.5][i % 5]}deg)`}
						>
							{fact}
						</span>
					))
				}
			</div>
		</section>

		<!-- story -->
		<section class="mx-auto max-w-6xl px-5 py-24 sm:px-10 sm:py-36">
			<div class="grid gap-14 md:grid-cols-12 md:gap-8">
				<div class="md:col-span-7">
					<p class="reveal font-mono text-[11px] tracking-[0.32em] text-clay uppercase">the origin story</p>
					<h1 class="reveal mt-5 font-display text-4xl leading-[1.06] font-medium tracking-tight sm:text-6xl" style="--reveal-delay: 0.08s">
						Photography is <Scribble kind="underline" color="var(--color-butter)">poetry</Scribble>
					</h1>
					<div class="reveal mt-8 max-w-xl space-y-5 text-lg leading-relaxed text-ink-soft" style="--reveal-delay: 0.16s">
						<p>
							Welcome to my page! My name is Madeleine — a Psychology major with a minor in
							business at Abilene Christian University. Born and raised in El Paso, TX, now
							calling the DFW area home.
						</p>
						<p>
							I found my passion for photography at a workshop held by Asia Joy, owner of Photo
							By Joy. All it took was one workshop and I was hooked — constantly craving more,
							wanting to learn everything I could. After four years of workshops I finally
							invested in myself, bought my own camera, and Madd Photography was born.
						</p>
					</div>
				</div>
				<div class="reveal relative md:col-span-4 md:col-start-9" style="--reveal-delay: 0.2s">
					<div class="photo-mat rotate-[2deg]">
						<Image
							src={maddieChair}
							alt="Maddie perched on an orange chair with her camera"
							widths={[480, 800]}
							sizes="(max-width: 768px) 88vw, 30vw"
							class="aspect-[4/5] w-full object-cover"
						/>
					</div>
					<span class="absolute -bottom-6 left-2 -rotate-3 font-hand text-2xl text-clay">first camera, no regrets</span>
				</div>
			</div>
		</section>

		<!-- hobbies band -->
		<section class="bg-cream">
			<div class="mx-auto max-w-5xl px-5 py-24 text-center sm:px-10 sm:py-32">
				<p class="reveal font-mono text-[11px] tracking-[0.32em] text-clay uppercase">when the camera’s down</p>
				<h2 class="reveal mt-5 font-display text-4xl font-medium tracking-tight sm:text-6xl" style="--reveal-delay: 0.08s">
					Dance parties &amp; love languages
				</h2>
				<p class="reveal mx-auto mt-8 max-w-xl text-lg leading-relaxed text-ink-soft" style="--reveal-delay: 0.16s">
					Photography is something I enjoy with every ounce of my being, but it’s not all of me. I
					love working out, talking about love languages, discovering new music, and having dance
					parties. Currently on repeat:
				</p>
				<div class="reveal mt-10 flex flex-wrap items-center justify-center gap-3 sm:gap-4" style="--reveal-delay: 0.24s">
					{
						artists.map((artist, i) => (
							<span
								class="sticker font-mono text-[11px] font-bold tracking-[0.14em] uppercase"
								style={`transform: rotate(${[-2, 1.5, -1.5, 2, -1][i % 5]}deg)`}
							>
								{i === artists.length - 1 && <Doodle name="heart" class="h-3.5 w-3.5 text-clay" />}
								{artist}
							</span>
						))
					}
				</div>
			</div>
		</section>

		<!-- style -->
		<section class="mx-auto max-w-6xl px-5 py-24 sm:px-10 sm:py-36">
			<div class="grid items-center gap-14 md:grid-cols-2 md:gap-12">
				<div class="reveal relative">
					<div class="photo-mat rotate-[-1.5deg]">
						<Image
							src={behindScenes}
							alt="Behind the scenes of Maddie directing a studio session"
							widths={[600, 1000, 1400]}
							sizes="(max-width: 768px) 92vw, 45vw"
							class="aspect-[16/10] w-full object-cover"
						/>
					</div>
					<span class="absolute -top-5 right-4 rotate-6 font-hand text-2xl text-clay">BTS, mid-hype</span>
				</div>
				<div>
					<p class="reveal font-mono text-[11px] tracking-[0.32em] text-clay uppercase">my style</p>
					<h2 class="reveal mt-5 font-display text-4xl leading-[1.08] font-medium tracking-tight sm:text-5xl" style="--reveal-delay: 0.08s">
						Guided, never posed
					</h2>
					<p class="reveal mt-8 max-w-lg text-lg leading-relaxed text-ink-soft" style="--reveal-delay: 0.16s">
						I’m all about being in the moment. Most people fear looking awkward in pictures
						because of prior photography experiences — I’m here to have fun and make you
						look <Scribble kind="ring" color="var(--color-clay)"><strong class="font-semibold text-ink">GOOD</strong></Scribble>.
					</p>
					<div class="reveal mt-10" style="--reveal-delay: 0.24s">
						<Button href="/galleries" variant="outline">See what that looks like</Button>
					</div>
				</div>
			</div>
		</section>

		<!-- cta -->
		<section class="mx-auto max-w-4xl px-5 pb-8 text-center sm:px-10">
			<Doodle name="smiley" class="reveal mx-auto h-10 w-10 text-clay" />
			<h2 class="reveal mt-6 font-display text-4xl font-medium tracking-tight sm:text-6xl" style="--reveal-delay: 0.08s">
				Want to work together?
			</h2>
			<div class="reveal mt-10" style="--reveal-delay: 0.16s">
				<Button href="/#contact">Contact me</Button>
			</div>
		</section>
	</main>
</Layout>
