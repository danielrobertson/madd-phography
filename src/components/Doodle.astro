---
// Hand-drawn doodle marks, stroke follows currentColor.
interface Props {
	name:
		| "star"
		| "sparkle"
		| "burst"
		| "heart"
		| "crown"
		| "camera"
		| "smiley"
		| "squiggle"
		| "arrow-curl"
		| "arrow-swoosh"
		| "flash";
	class?: string;
	[key: string]: unknown;
}
const { name, class: className = "", ...rest } = Astro.props;

const paths: Record<string, string> = {
	// four-point sparkle star
	star: "M24 4c1.2 7.4 2.9 11.7 5.8 14.6C32.7 21.5 37 23 44 24c-7 1.3-11.3 2.9-14.2 5.8C26.9 32.7 25.2 37 24 44c-1.2-7-2.9-11.3-5.8-14.2C15.3 26.9 11 25.3 4 24c7-1 11.3-2.6 14.2-5.5C21.1 15.6 22.8 11.4 24 4Z",
	// three excited dashes
	sparkle: "M14 30 8 40 M24 26v14 M34 30l6 10",
	// asterisk burst
	burst: "M24 8v32 M10 15l28 18 M38 15 10 33",
	heart: "M24 40C15 33 8 27 8 19.5 8 14 12 10 17 10c3.2 0 5.7 1.6 7 4.4C25.3 11.6 27.8 10 31 10c5 0 9 4 9 9.5 0 7.5-7 13.5-16 20.5Z",
	crown: "M8 34 5 14l10 7 9-13 9 13 10-7-3 20c-8-2.5-24-2.5-32 0Zm0 6c9-2.5 23-2.5 32 0",
	camera: "M8 16h7l3-5h12l3 5h7c1.6 0 3 1.4 3 3v17c0 1.6-1.4 3-3 3H8c-1.6 0-3-1.4-3-3V19c0-1.6 1.4-3 3-3Zm16 4.5a6.5 6.5 0 1 1 0 13 6.5 6.5 0 0 1 0-13Z M36 21h2",
	smiley: "M24 5a19 19 0 1 1 0 38 19 19 0 0 1 0-38Zm-8 15h.2m15.8 0h.2M15 28c2.4 3.8 5.4 5.6 9 5.6s6.6-1.8 9-5.6",
	squiggle: "M4 26c3-6 6-6 9 0s6 6 9 0 6-6 9 0 6 6 9 0",
	// loopy arrow pointing down-right
	"arrow-curl":
		"M8 6c10 2 14 8 12 14s-9 8-12 4 2-10 10-9c10 1.4 16 10 18 24 M30 32l6 8 8-5",
	// simple swooshy arrow pointing right
	"arrow-swoosh": "M4 32C14 20 28 16 42 20 M35 12l8 7-9 5",
	flash: "M26 4 12 28h10l-4 16L38 20H27l5-16h-6Z",
};
---

<svg
	class={className}
	{...rest}
	viewBox="0 0 48 48"
	fill="none"
	stroke="currentColor"
	stroke-width="2.6"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
>
	<path d={paths[name]}></path>
</svg>
