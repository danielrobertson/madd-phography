---
// Wraps a word with a hand-drawn oval ring or a wobbly underline.
interface Props {
	kind?: "ring" | "underline";
	color?: string;
	class?: string;
}
const { kind = "ring", color = "currentColor", class: className = "" } = Astro.props;
---

{
	kind === "ring" ? (
		<span class={`scribble-ring ${className}`}>
			<slot />
			<svg viewBox="0 0 200 70" fill="none" preserveAspectRatio="none" aria-hidden="true">
				<path
					d="M96 8C48 6 8 16 6 35c-2 20 42 30 96 29 52-1 94-12 92-30C192 17 156 4 112 6c-30 1.4-52 6-64 11"
					stroke={color}
					stroke-width="3"
					stroke-linecap="round"
				/>
			</svg>
		</span>
	) : (
		<span class={`scribble-under ${className}`}>
			<slot />
			<svg viewBox="0 0 220 14" fill="none" preserveAspectRatio="none" aria-hidden="true">
				<path
					d="M4 9C40 4 80 3 216 6M30 11c60-4 120-4 160-3"
					stroke={color}
					stroke-width="3"
					stroke-linecap="round"
				/>
			</svg>
		</span>
	)
}
